# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Meta / Facebook (LEGACY — single global, used only if per-tenant config not set) ──
# Your custom webhook verify token (any random string you choose)
META_VERIFY_TOKEN=your_meta_verify_token_here

# WhatsApp Cloud API — from Meta Developer Console > WhatsApp > API Setup
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
# The Phone Number ID (not the phone number itself)
WA_PHONE_NUMBER_ID=your_phone_number_id_here

# Instagram Messaging — Page Access Token for your Instagram Business account
IG_PAGE_ACCESS_TOKEN=your_instagram_page_access_token_here

# Facebook Messenger — Page Access Token for your Facebook Page
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ─── Google Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Random secret for session cookie (generate with: openssl rand -hex 32)
ADMIN_SESSION_SECRET=generate_with_openssl_rand_hex_32

# ─── Database ────────────────────────────────────────────────────────────────
# Optional: override default SQLite file location
# DB_PATH=/absolute/path/to/salon.db

# ─── Multi-Tenant Configuration ───────────────────────────────────────────────
# Super admin database path
SUPER_DB_PATH=./super.db

# JWT Secret for tenant authentication — REQUIRED (generate with: openssl rand -hex 32)
TENANT_JWT_SECRET=generate_with_openssl_rand_hex_32

# Run migration on startup (set to 'true' only once, then change to 'false')
RUN_MIGRATION=false

# Environment (development/production)
NODE_ENV=development

# ─── Widget Configuration ────────────────────────────────────────────────────
WIDGET_ALLOWED_ORIGINS=*