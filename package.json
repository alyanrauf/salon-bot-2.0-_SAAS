{
  "name": "salon-bot",
  "version": "1.0.0",
  "description": "Automated messaging and booking bot for a beauty salon across WhatsApp, Instagram, and Facebook Messenger",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --ignore data/ src/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --prefix frontend\"",
    "start:all": "concurrently \"npm run start\" \"npm run start --prefix frontend\"",
    "seed": "node src/db/seed.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
